# Backends Supabase — copie para .env.local e preencha.

# CRM (projeto "SaaS Lolze") — tabelas app_leads / app_mensagens / app_trafego
NEXT_PUBLIC_SUPABASE_CRM_URL=https://pphstbiwcaeldaoesuwl.supabase.co
NEXT_PUBLIC_SUPABASE_CRM_KEY=sb_publishable_iua4p_TtA170G5zq4meDzQ_2ztw9sl7
# Service role do CRM (SECRETA, server-only). Necessária para cadastrar clientes
# pelo painel admin (criar usuarios). Settings > API > service_role no projeto SaaS Lolze.
SUPABASE_CRM_SERVICE_KEY=
# OpenAI (SECRETA, server-only). Usada para gerar embeddings da Base de Conhecimento (RAG).
# Modelo: text-embedding-3-small. platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic (SECRETA, server-only). É o CÉREBRO do SDR no app (Claude). console.anthropic.com
ANTHROPIC_API_KEY=

# AGENDA (projeto "agendamento-estetica") — appointments, services
NEXT_PUBLIC_SUPABASE_AGENDA_URL=https://istysllrmktjbsfhtqrd.supabase.co
NEXT_PUBLIC_SUPABASE_AGENDA_KEY=sb_publishable_D-9xmLFMhXWPP_tNpQ17kg_LmoOc4JU
